# API Keys and Configuration

# Pixabay API key for copyright-free music auto-download
# Get a free key: https://pixabay.com/accounts/register/ then https://pixabay.com/api/docs/
PIXABAY_API_KEY=your-pixabay-key-here

# LLM Provider Keys (pick one, or let the CLI auto-detect)
# OpenRouter (free, recommended) - https://openrouter.ai/
OPENROUTER_API_KEY=sk-...

# Anthropic Claude API - https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API - https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Optional: Override OpenRouter model
# OPENROUTER_MODEL=meta-llama/llama-3.1-70b-instruct:free
