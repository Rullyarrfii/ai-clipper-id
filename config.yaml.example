# AI Clipper Configuration
# Copy this file to config.yaml and customize your settings

# ── Background Music Library ──────────────────────────────────────────────
# Define your music library with mood categories.
# The LLM will match clips to music based on these descriptions.
# Place the actual .mp3 files in the music_dir specified below.

music_library:
  - id: upbeat_pop
    category: upbeat
    mood: "energetic, happy, motivational, fun"
    description: "Upbeat pop/electronic beat — great for tips, tutorials, success stories"
    file: upbeat_pop.mp3

  - id: chill_lofi
    category: chill
    mood: "relaxed, calm, thoughtful, cozy"
    description: "Lo-fi hip hop chill beat — perfect for storytelling, explanations, reflections"
    file: chill_lofi.mp3

  - id: dramatic_cinematic
    category: dramatic
    mood: "intense, serious, suspenseful, emotional"
    description: "Cinematic orchestral — for shocking reveals, serious topics, emotional moments"
    file: dramatic_cinematic.mp3

  - id: inspiring_ambient
    category: inspiring
    mood: "hopeful, uplifting, inspirational, warm"
    description: "Ambient inspirational — for motivational content, success stories, advice"
    file: inspiring_ambient.mp3

  - id: tech_electronic
    category: tech
    mood: "futuristic, modern, innovative, fast"
    description: "Electronic/tech beat — for tech topics, innovation, how-tos, demonstrations"
    file: tech_electronic.mp3

  - id: funny_quirky
    category: funny
    mood: "comedic, playful, silly, lighthearted"
    description: "Quirky comedic — for funny moments, memes, roasts, lighthearted content"
    file: funny_quirky.mp3

  - id: sad_piano
    category: emotional
    mood: "sad, melancholic, touching, sentimental"
    description: "Soft piano — for emotional stories, heartfelt moments, personal sharing"
    file: sad_piano.mp3

  - id: hype_trap
    category: hype
    mood: "aggressive, confident, bold, powerful"
    description: "Trap/bass beat — for bold claims, confrontational takes, confidence, hype"
    file: hype_trap.mp3

# ── Default CLI Parameters ────────────────────────────────────────────────
# These values are used as defaults when running the CLI.
# You can still override them via command-line arguments.

defaults:
  # Whisper transcription model
  whisper_model: turbo  # Options: tiny, base, small, medium, large-v2, large-v3, distil-large-v3, turbo

  # Language code (or null for auto-detect)
  language: id  # 'id' for Indonesian, 'en' for English, null for auto-detect

  # Clip duration range (seconds)
  min_clip_duration: 15
  max_clip_duration: 180

  # Maximum number of clips to generate
  max_clips: 10

  # Minimum engagement score to keep a clip
  min_score: 55

  # Compute settings
  device: auto  # Options: auto, cuda, cpu
  compute_type: auto  # Options: auto, float16, int8, int8_float16
  batch_size: 16

  # VAD (Voice Activity Detection) settings
  vad_enabled: true
  vad_min_silence_ms: 400
  vad_speech_pad_ms: 200

  # LLM chunking settings
  chunk_duration: 360.0  # seconds
  chunk_overlap: 60.0    # seconds

  # Output directory (relative to project root)
  output_dir: clips

  # ── Post-processing Defaults ────────────────────────────────────────────

  # Subtitles
  subtitles_enabled: true
  subtitle_position: lower  # Options: center, upper, lower
  subtitle_margin_pct: 25.0  # Margin from bottom for "lower" position (in %). Use 0.0 for center, 5.0 for upper.

  # Person detection & crop
  crop_enabled: false
  crop_target: vertical  # Options: vertical, horizontal, square

  # Background music
  music_enabled: false
  music_dir: music
  music_volume: 0.06  # 0.0-1.0 (very quiet by default)

  # Silence removal
  silence_removal_enabled: true
  max_silence_duration: 1.5  # seconds

# ── Instagram CTA ─────────────────────────────────────────────────────────
# When enabled, each clip ends with a fade-to-black "Follow us on Instagram"
# screen — animated account name, username, and a "Follow" button with a
# click sound effect.
#
# Set enabled: true to activate. All other fields are required when enabled.

cta:
  enabled: false
  name: "Samuel Academy"          # Display name shown on the CTA screen
  username: "@samuelkoesnadi"     # Instagram handle (@ prefix optional)
  duration: 3.0                   # Duration of the CTA screen in seconds
  fade_duration: 0.5              # Cross-fade length from clip to CTA (seconds)

# ── Pixabay Music Download Settings ───────────────────────────────────────
# Used when auto-downloading music library

pixabay:
  min_duration: 30  # Minimum track duration in seconds
  per_page: 5       # Number of results per search
